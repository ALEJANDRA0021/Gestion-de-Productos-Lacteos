@model List<Gestion_de_Productos_Lacteos.Models.ViewModels.VentaRegistroViewModel>

@{
    ViewData["Title"] = "Historial de Ventas";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var ventas = Model ?? new List<Gestion_de_Productos_Lacteos.Models.ViewModels.VentaRegistroViewModel>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">
            <i class="fas fa-history me-2" style="color: #9b59b6;"></i>
            Historial de Ventas
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus-circle me-1"></i> Nueva Venta
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card stat-card-purple text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Total Ventas</h6>
                            <h2 class="mb-0">@ventas.Count</h2>
                        </div>
                        <i class="fas fa-chart-line fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card stat-card-green text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Total Recaudado</h6>
                            <h4 class="mb-0">@ventas.Sum(v => v.Total)?.ToString("C")</h4>
                        </div>
                        <i class="fas fa-dollar-sign fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card stat-card-pink text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Ventas Hoy</h6>
                            <h2 class="mb-0">@ventas.Count(v => v.FechaVenta.Date == DateTime.Now.Date)</h2>
                        </div>
                        <i class="fas fa-calendar-day fa-2x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th># Venta</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Total</th>
                            <th>Productos</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venta in ventas)
                        {
                            <tr>
                                <td class="fw-bold">@venta.IdVenta</td>
                                <td>@venta.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <i class="fas fa-user me-1" style="color: #9b59b6;"></i>
                                    @venta.NombreCliente
                                </td>
                                <td class="text-success fw-bold">@venta.Total?.ToString("C")</td>
                                <td>
                                    <span class="badge bg-info">@venta.Detalles.Count productos</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@venta.IdVenta" class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-eye"></i> Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!ventas.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fas fa-shopping-cart fa-3x mb-3 opacity-50"></i>
                                    <p class="mb-0">No hay ventas registradas</p>
                                    <a asp-action="Create" class="btn btn-primary btn-sm mt-3">Registrar primera venta</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>